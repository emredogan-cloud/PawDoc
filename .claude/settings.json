{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(dart format:*)",
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(ruff:*)",
      "Bash(.venv/bin/ruff:*)",
      "Bash(node --test:*)",
      "Bash(./scripts/test-rls.sh:*)",
      "Bash(./scripts/verify-disclaimers.sh:*)",
      "Bash(./scripts/verify-phase-:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(git:*)",
      "Bash(flutter build:*)"

    ],
    "ask": [
      "Bash(fly deploy:*)",
      "Bash(flyctl deploy:*)",
      "Bash(supabase functions deploy:*)",
      "Bash(supabase db push:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .git)",
      "Bash(rm -rf .git/*)"
    ]
  }
}
