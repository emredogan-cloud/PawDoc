# ai-service environment variables.
# Copy to `.env` for local dev. NEVER commit `.env`. In prod, Doppler injects
# these directly into the container env at deploy time.

# ---- Runtime ----------------------------------------------------------------
APP_ENV=local                 # local | dev | prod
LOG_LEVEL=DEBUG               # DEBUG | INFO | WARNING | ERROR
PORT=8080
ALLOWED_ORIGINS=http://localhost:*

# ---- Supabase (Phase 1) -----------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI providers (Phase 1) -------------------------------------------------
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

# ---- Cloudflare R2 (Phase 1) ------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pawdoc-uploads-dev

# ---- Upstash Redis (Phase 1, semantic cache) --------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=0.1.0+local

# ---- AI orchestration (Phase 1B) -------------------------------------------
# Shared secret with the Supabase Edge Function. Set the same value there
# (via `supabase secrets set INTERNAL_API_TOKEN=...`).
INTERNAL_API_TOKEN=

# Override default model versions if needed.
GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Provider timeouts (seconds). Tune per region.
GEMINI_TIMEOUT_S=20
CLAUDE_TIMEOUT_S=30

# Routing thresholds — generally leave as default.
TIER2_CONFIDENCE_FLOOR=0.85
INSUFFICIENT_CONFIDENCE_FLOOR=0.60
