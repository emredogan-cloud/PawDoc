*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
coverage.xml
.coverage
.coverage.*
tests/
docs/
*.md
!README.md
Dockerfile
.dockerignore
docker-compose.yml
fly.toml
