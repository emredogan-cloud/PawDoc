# PawDoc web — PUBLIC build-time config, inlined into the static export by Next.
# Set these as Cloudflare Pages environment variables (Production + Preview).
# All are publishable/public values — safe to ship to the browser.

# Supabase project (the anonymous web checker calls the /analyze-anonymous fn).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLISHABLE-KEY

# Cloudflare Turnstile SITE key (the SECRET key lives only on the Edge Function;
# see docs/runbooks/21-web-checker.md).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR-TURNSTILE-SITE-KEY
