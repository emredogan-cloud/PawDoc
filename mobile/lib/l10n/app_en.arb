{
  "@@locale": "en",

  "appTitle": "PawDoc",
  "@appTitle": { "description": "Application name." },

  "emergencyTitle": "This may be an emergency",
  "@emergencyTitle": { "description": "Emergency result screen heading (CR #11 safety-critical)." },

  "emergencyRecommendedPrefix": "Recommended: {timeframe}.",
  "@emergencyRecommendedPrefix": {
    "description": "Recommended urgency timeframe line on the emergency screen.",
    "placeholders": { "timeframe": { "type": "String", "example": "immediately" } }
  },

  "emergencyIndicatorDetected": "Emergency indicator detected: '{indicator}'.",
  "@emergencyIndicatorDetected": {
    "description": "M0 F-3: localized wrapper for the server's emergency-override primary_concern template. The quoted indicator is the matched keyword (already in the user's locale — safety.py keyword lists are per-locale) and is never altered.",
    "placeholders": { "indicator": { "type": "String", "example": "not breathing" } }
  },

  "urgencyImmediately": "immediately",
  "@urgencyImmediately": { "description": "M0 F-3: display value for the wire urgency_timeframe 'immediately' (contract stays English on the wire)." },

  "urgencyWithin24Hours": "within 24 hours",
  "@urgencyWithin24Hours": { "description": "M0 F-3: display value for the wire urgency_timeframe 'within 24 hours'." },

  "urgencyRoutine": "routine",
  "@urgencyRoutine": { "description": "M0 F-3: display value for the wire urgency_timeframe 'routine'." },

  "emergencyFindVet": "Find an emergency vet now",
  "@emergencyFindVet": { "description": "Primary CTA on the emergency screen — safety-critical." },

  "emergencyDisclaimer": "PawDoc provides information, not a diagnosis. In an emergency, contact a veterinarian immediately.",
  "@emergencyDisclaimer": { "description": "Server-injected disclaimer line on EMERGENCY (always shown when required)." },

  "resultDisclaimer": "PawDoc provides information, not a veterinary diagnosis. When in doubt, contact your vet.",
  "@resultDisclaimer": { "description": "GAP-E13: server-forced disclaimer on the standard (MONITOR/NORMAL) result screen, shown when disclaimer_required is true." },

  "emergencyAcknowledge": "I understand this needs urgent attention",
  "@emergencyAcknowledge": { "description": "Acknowledgment checkbox label." },

  "actionContinue": "Continue",
  "@actionContinue": { "description": "Generic Continue button." },

  "telehealthTitle": "Talk to a vet now",
  "@telehealthTitle": { "description": "Telehealth CTA title (Airvet-style affiliate)." },

  "telehealthSubtitle": "On-demand video consult with a licensed vet.",
  "@telehealthSubtitle": { "description": "Telehealth CTA subtitle." },

  "telehealthCta": "Consult a vet",
  "@telehealthCta": { "description": "Telehealth button label." }
}
