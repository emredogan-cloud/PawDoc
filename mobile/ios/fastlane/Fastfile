# PawDoc — iOS release lanes (GAP-B4). Run from mobile/ios:
#   bundle exec fastlane ios build      # signed .ipa, no upload
#   bundle exec fastlane ios beta        # -> TestFlight   (release.yml calls this on v* tags)
#   bundle exec fastlane ios release     # -> App Store review (no auto-release)
#
# Signing uses `match` (certs/profiles in a PRIVATE repo, readonly on CI). All
# secrets come from ENV (see ../../../fastlane/README.md +
# docs/runbooks/11-fastlane-match.md) — never hardcode keys. NONE of these run
# by default; CI invokes `beta` only on an explicit v* tag.
require "shellwords"

flutter_root = File.expand_path("../..", __dir__) # mobile/ios/fastlane -> mobile

default_platform(:ios)

platform :ios do
  # App Store Connect API key — shared by every Apple-facing lane.
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"]
    )
  end

  desc "Build a signed App Store .ipa with Flutter. No upload."
  lane :build do
    sh("cd #{flutter_root.shellescape} && flutter build ipa --release --export-method app-store")
    UI.success("IPA built under #{flutter_root}/build/ios/ipa")
  end

  desc "Build + upload to TestFlight (beta)."
  lane :beta do
    setup_ci if ENV["CI"] # ephemeral keychain on CI runners
    asc_api_key
    match(type: "appstore", readonly: true)
    build
    pilot(
      skip_waiting_for_build_processing: true,
      ipa: Dir.glob(File.join(flutter_root, "build/ios/ipa/*.ipa")).first
    )
  end

  desc "Build + submit to the App Store for review (manual release, not automatic)."
  lane :release do
    setup_ci if ENV["CI"]
    asc_api_key
    match(type: "appstore", readonly: true)
    build
    deliver(
      ipa: Dir.glob(File.join(flutter_root, "build/ios/ipa/*.ipa")).first,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false
    )
  end
end
