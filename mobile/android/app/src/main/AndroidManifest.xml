<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Sprint B3 / founder real-device test:
      Permissions required for the analyze pipeline on Android 13+:
        - INTERNET           HTTP + Supabase + AI service calls
        - ACCESS_NETWORK_STATE   connectivity_plus offline detection
        - CAMERA             image_picker camera capture
      We deliberately do NOT request:
        - READ_MEDIA_IMAGES — image_picker's photo-picker is permissionless
          on Android 13+ via the system PhotoPicker UI.
        - WRITE_EXTERNAL_STORAGE — never needed; we only read picked files.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.CAMERA"/>
    <!-- CAMERA is "optional" so the app installs on tablets without one;
         the runtime-permission flow inside image_picker handles the rest. -->
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <application
        android:label="pawdoc"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!--
      Package-visibility queries (Android 11+, API 30+).
      Without these, intent-resolving plugins silently fail on real devices.
    -->
    <queries>
        <!-- Default Flutter engine: process-text targets. -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- url_launcher: paywall Terms/Privacy links + future deep links. -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="https"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:scheme="http"/>
        </intent>
        <!-- image_picker camera path. -->
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE"/>
        </intent>
    </queries>
</manifest>
