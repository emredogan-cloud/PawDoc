# =============================================================================
# PawDoc — repository-level .env.example (ORIENTATION ONLY)
# =============================================================================
# This file lists EVERY secret used anywhere in the monorepo so a new developer
# can see the full surface area at a glance. Real secrets live in Doppler.
#
# Each service ALSO has its own scoped .env.example:
#   - ai-service/.env.example
#   - mobile/env/dev.json.example
#   - mobile/env/prod.json.example
#
# To bring up local dev, copy each scoped example into the un-suffixed name and
# fill in values from Doppler / your accounts. NEVER copy this root file into a
# live `.env` — it is a documentation artifact.
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
# `local` URL is what `supabase start` prints — used by ai-service and mobile
# when developing offline. `dev` and `prod` are real Supabase projects.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...                  # public-safe, signed JWT, embedded in mobile app
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # server-only, bypasses RLS — NEVER ships in mobile

# ---- Cloudflare R2 ----------------------------------------------------------
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET=pawdoc-uploads-dev
R2_PUBLIC_BASE_URL=https://uploads.pawdoc.app

# ---- AI providers -----------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
OPENAI_API_KEY=sk-...                     # text-embedding-3-small only (semantic cache)

# ---- Upstash Redis (semantic cache) -----------------------------------------
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ---- Observability ----------------------------------------------------------
SENTRY_DSN_MOBILE=https://...@sentry.io/...
SENTRY_DSN_AI_SERVICE=https://...@sentry.io/...
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=0.1.0+local

# ---- Analytics --------------------------------------------------------------
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://eu.posthog.com

# ---- RevenueCat -------------------------------------------------------------
REVENUECAT_PUBLIC_KEY_IOS=appl_...
REVENUECAT_PUBLIC_KEY_ANDROID=goog_...
REVENUECAT_WEBHOOK_AUTH_TOKEN=...         # validates incoming webhooks server-side

# ---- OneSignal --------------------------------------------------------------
ONESIGNAL_APP_ID=...
ONESIGNAL_REST_API_KEY=...

# ---- Fly.io / deployment ----------------------------------------------------
FLY_API_TOKEN=...                         # CI use only

# ---- AI service runtime config ----------------------------------------------
APP_ENV=local                             # local | dev | prod
LOG_LEVEL=INFO                            # DEBUG | INFO | WARNING | ERROR
PORT=8080
ALLOWED_ORIGINS=http://localhost:*,supabase://*
